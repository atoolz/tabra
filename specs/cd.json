{
  "name": "cd",
  "description": "Change the shell working directory",
  "args": {
    "generators": {
      "trigger": {
        "__tabra_function": true,
        "path": ".args.generators.trigger"
      },
      "getQueryTerm": {
        "__tabra_function": true,
        "path": ".args.generators.getQueryTerm"
      },
      "custom": {
        "__tabra_function": true,
        "path": ".args.generators.custom"
      }
    },
    "filterStrategy": "fuzzy",
    "suggestions": [
      {
        "name": "-",
        "description": "Switch to the last used folder",
        "hidden": true
      },
      {
        "name": "~",
        "description": "Switch to the home directory",
        "hidden": true
      }
    ]
  }
}
